# NanoClaw Configuration Template
# Copy this to .env and fill in your private details

# --- GEMINI API ---
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash

# --- CHANNEL CONFIG ---
DISCORD_BOT_TOKEN=your_discord_bot_token_here

# --- KUBERNETES CONFIG ---
K8S_NAMESPACE=nanoclaw
K8S_PVC_NAME=nanoclaw-pvc-final
K8S_PVC_SUBPATH=.

# --- REGISTRY CONFIG ---
# Used for autonomous evolution and project building
REGISTRY_URL=<YOUR_REGISTRY_IP>:30500
CONTAINER_IMAGE_BASE=nanoclaw

# --- LOGGING ---
LOG_LEVEL=info
